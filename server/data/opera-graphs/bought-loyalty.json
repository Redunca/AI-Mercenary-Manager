{
  "id": "bought-loyalty",
  "title": "Bought Loyalty",
  "description": "A faction/corporation controlling a planet extends a hand. The crew decides how much it's worth, and whether to hold up their end.",
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "text": "Contact from {faction}, controlling {planetName}, has been logged. Leadership indicates interest in a working relationship, contingent on a demonstration of good faith.",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "act1-tribute",
      "type": "seed",
      "seeds": [
        {
          "target": "shop",
          "params": {
            "itemName": "Tribute Cache"
          },
          "note": "A one-off tribute item for the faction contact."
        }
      ],
      "completionText": "Tribute Cache handed over.",
      "position": {
        "x": 300,
        "y": -150
      }
    },
    {
      "id": "act1-contact",
      "type": "mission",
      "mission": {
        "title": "Locate {faction}'s Contact",
        "description": "A verified contact within {faction}, {distance}, has gone silent. Re-establish the line before goodwill erodes.",
        "difficulty": "ROUTINE",
        "tags": [
          "recon"
        ]
      },
      "completionText": "Contact re-established.",
      "position": {
        "x": 300,
        "y": 0
      }
    },
    {
      "id": "act1-capture",
      "type": "mission",
      "mission": {
        "title": "Detain a {faction} Defector",
        "description": "{faction} has flagged a low-level troublemaker for retrieval as a gesture of cooperation. Target last confirmed near {planetName}.",
        "difficulty": "STANDARD",
        "tags": [
          "extraction"
        ]
      },
      "completionText": "Target detained and handed over.",
      "position": {
        "x": 300,
        "y": 150
      }
    },
    {
      "id": "bridge-1",
      "type": "story",
      "text": "{faction} acknowledges the gesture. A formal introduction is arranged on {planetName}.",
      "position": {
        "x": 600,
        "y": 0
      }
    },
    {
      "id": "act2-negotiate",
      "type": "mission",
      "mission": {
        "title": "Negotiate Terms with {faction}",
        "description": "Meet {clientName}, {faction}'s liaison, on {planetName} to formalize terms.",
        "difficulty": "STANDARD",
        "tags": [
          "diplomacy"
        ]
      },
      "completionText": "Terms discussed.",
      "position": {
        "x": 900,
        "y": -150
      }
    },
    {
      "id": "act2-rescue",
      "type": "mission",
      "mission": {
        "title": "Recover {targetName}",
        "description": "A member of {faction} has gone missing near {planetName}. Retrieval is expected in exchange for standing.",
        "difficulty": "HARD",
        "tags": [
          "extraction"
        ]
      },
      "completionText": "{targetName} recovered.",
      "position": {
        "x": 900,
        "y": 0
      }
    },
    {
      "id": "act2-job",
      "type": "mission",
      "mission": {
        "title": "Run a Job for {faction}",
        "description": "{faction} has work that needs doing under their name, not the crew's. The shape of it is theirs to decide."
      },
      "completionText": "Job completed under {faction}'s banner.",
      "position": {
        "x": 900,
        "y": 150
      }
    },
    {
      "id": "bridge-2",
      "type": "story",
      "text": "{faction} takes note. Word of the crew's reliability spreads through their ranks on {planetName}.",
      "position": {
        "x": 1200,
        "y": 0
      }
    },
    {
      "id": "act3-retaliation",
      "type": "mission",
      "mission": {
        "title": "Weather {faction}'s Rivals",
        "description": "{enemyGroupName} has taken exception to {faction}'s new friends. An attempt on the crew is expected {distance}.",
        "difficulty": "HARD",
        "tags": [
          "combat"
        ]
      },
      "completionText": "The attempt is repelled.",
      "position": {
        "x": 1500,
        "y": -150
      }
    },
    {
      "id": "act3-debt",
      "type": "seed",
      "seeds": [
        {
          "target": "shop",
          "params": {
            "itemName": "Old Debt Note"
          },
          "note": "A debt {faction} owes a third party, buyable out from under them."
        }
      ],
      "completionText": "Debt bought out.",
      "position": {
        "x": 1500,
        "y": 0
      }
    },
    {
      "id": "act3-gift",
      "type": "story",
      "text": "{faction} leadership hints that a real sacrifice would seal their trust -- one of the crew's own, released to serve under their banner.",
      "effects": [],
      "position": {
        "x": 1500,
        "y": 150
      }
    },
    {
      "id": "bridge-3",
      "type": "story",
      "text": "{faction}'s leadership convenes to decide what the crew has earned.",
      "position": {
        "x": 1800,
        "y": 0
      }
    },
    {
      "id": "finale-choice",
      "type": "choice",
      "text": "How should the crew's arrangement with {faction} be settled?",
      "choiceOptions": [
        {
          "id": "alliance",
          "label": "Formalize the alliance"
        },
        {
          "id": "seize",
          "label": "Take {faction}'s assets while trust is highest"
        },
        {
          "id": "walkaway",
          "label": "Take the standing already earned and walk away"
        }
      ],
      "position": {
        "x": 2100,
        "y": 0
      }
    },
    {
      "id": "finale-alliance-seed",
      "type": "seed",
      "seeds": [
        {
          "target": "candidate",
          "params": {
            "seedId": "bought-loyalty-defector"
          },
          "note": "A disillusioned faction operative who defects once the alliance is formalized."
        }
      ],
      "completionText": "The defector reaches out, ready to join.",
      "position": {
        "x": 2400,
        "y": -150
      }
    },
    {
      "id": "finale-alliance-payoff",
      "type": "story",
      "text": "{faction} formalizes the alliance.",
      "effects": [
        {
          "type": "apply_perk",
          "params": {
            "perkName": "Diplomatic Standing"
          }
        }
      ],
      "position": {
        "x": 2700,
        "y": -150
      }
    },
    {
      "id": "finale-alliance-end",
      "type": "end",
      "outcome": "success",
      "text": "The defector signs on, and {planetName} opens its doors a little wider to the crew.",
      "position": {
        "x": 3000,
        "y": -150
      }
    },
    {
      "id": "finale-seize-mission",
      "type": "mission",
      "mission": {
        "title": "Seize {faction}'s Assets",
        "description": "Trust runs highest right now. A window exists to strip {faction} of its holdings on {planetName} before they see it coming.",
        "difficulty": "PERILOUS",
        "tags": [
          "heist"
        ]
      },
      "completionText": "The assets are seized.",
      "position": {
        "x": 2400,
        "y": 0
      }
    },
    {
      "id": "finale-seize-payoff",
      "type": "story",
      "text": "The crew's cut comes through.",
      "effects": [
        {
          "type": "give_item",
          "params": {
            "itemName": "Seized Assets Ledger"
          }
        },
        {
          "type": "apply_flaw",
          "params": {
            "flawName": "Marked Rival"
          }
        }
      ],
      "position": {
        "x": 2700,
        "y": 0
      }
    },
    {
      "id": "finale-seize-success-end",
      "type": "end",
      "outcome": "success",
      "text": "{faction}'s holdings on {planetName} change hands. The crew walks away richer, and thoroughly burned as an ally.",
      "position": {
        "x": 3000,
        "y": 0
      }
    },
    {
      "id": "finale-seize-failure-payoff",
      "type": "story",
      "text": "{faction} sees the betrayal coming.",
      "effects": [
        {
          "type": "apply_flaw",
          "params": {
            "flawName": "Marked Enemy"
          }
        }
      ],
      "position": {
        "x": 2700,
        "y": 150
      }
    },
    {
      "id": "finale-seize-failure-end",
      "type": "end",
      "outcome": "failure",
      "text": "The seizure is repelled. {faction}'s leadership on {planetName} now considers the crew a threat.",
      "position": {
        "x": 3000,
        "y": 150
      }
    },
    {
      "id": "finale-walkaway-end",
      "type": "end",
      "outcome": "neutral",
      "text": "The crew banks the standing already earned and steps back before it can curdle into obligation.",
      "position": {
        "x": 2400,
        "y": 150
      }
    }
  ],
