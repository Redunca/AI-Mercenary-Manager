{
  "id": "tutorial",
  "title": "Basic Operations",
  "description": "A guided walkthrough of the terminal and the core loop: crew, missions, gear, and the shop.",
  "nodes": [
    { "id": "start", "type": "start", "text": "Welcome aboard, Commander. This log will walk you through the basics.", "position": { "x": 0, "y": 0 } },
    { "id": "learn-split-v", "type": "story", "text": "This terminal is made of panels. Try splitting this one vertically: type split-v.", "completionText": "Panel split vertically.", "position": { "x": 300, "y": 0 } },
    { "id": "learn-split-h", "type": "story", "text": "Now try splitting a panel horizontally: type split-h.", "completionText": "Panel split horizontally.", "position": { "x": 600, "y": 0 } },
    { "id": "learn-help", "type": "story", "text": "If you ever forget a command, type help.", "completionText": "Help panel opened. It's always there if you need it.", "position": { "x": 900, "y": 0 } },
    { "id": "hire-a-recruit", "type": "story", "text": "Time to build your crew. Open a candidate and type hire, or use recruit hire <id>.", "completionText": "New recruit hired.", "position": { "x": 1200, "y": 0 } },
    { "id": "assign-recruit-to-ship", "type": "story", "text": "A recruit isn't much use standing around the hangar. Assign them to a ship: ship assign <shipId> <recruitId>.", "completionText": "Recruit assigned to ship.", "position": { "x": 1500, "y": 0 } },
    { "id": "complete-a-mission", "type": "story", "text": "Send that crewed ship on a mission: mission start <templateId> <shipId>.", "completionText": "First mission complete.", "position": { "x": 1800, "y": 0 } },
    { "id": "buy-seeded-equipment", "type": "story", "text": "The shop always stocks a Recruit Training Vest. Buy one: shop buy <itemId>.", "completionText": "Recruit Training Vest purchased.", "position": { "x": 2100, "y": 0 } },
    { "id": "equip-vest-to-recruit", "type": "story", "text": "Gear doesn't help anyone in the stash. Equip it from a recruit's detail panel: equip <equipmentId>.", "completionText": "Vest equipped.", "position": { "x": 2400, "y": 0 } },
    { "id": "buy-seeded-item", "type": "story", "text": "The shop also always stocks an Encrypted Data Chip. Buy one: shop buy <itemId>.", "completionText": "Encrypted Data Chip purchased.", "position": { "x": 2700, "y": 0 } },
    { "id": "load-item-onto-ship", "type": "story", "text": "Items in the stash do nothing. Load it onto a ship: ship load <shipId> <consumableId>.", "completionText": "Item loaded onto ship.", "position": { "x": 3000, "y": 0 } },
    { "id": "complete-another-mission", "type": "story", "text": "Send your crew out again: mission start <templateId> <shipId>.", "completionText": "Second mission complete.", "position": { "x": 3300, "y": 0 } },
    { "id": "open-self", "type": "story", "text": "One more thing: type self to see your own upgrades.", "completionText": "Self panel opened.", "position": { "x": 3600, "y": 0 } },
    { "id": "end-success", "type": "end", "outcome": "success", "text": "Basic training complete. You're on your own from here, Commander.", "position": { "x": 3900, "y": 0 } }
  ],
